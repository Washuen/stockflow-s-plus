# StockFlow S Plus — Environment Example
# Copie este arquivo para .env no ambiente local.
# Nunca suba o arquivo .env real para o GitHub.

# Application
NODE_ENV=development
PORT=3333

# Database
# Local example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockflow?schema=public"

# Production example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Authentication
JWT_SECRET="change-this-secret-before-production"
JWT_EXPIRES_IN="7d"

# Optional
APP_NAME="StockFlow S Plus"
APP_URL="http://localhost:3333"
